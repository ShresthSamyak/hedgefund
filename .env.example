# AlphaGrid environment template — copy to .env and fill in.
# Never commit .env (see .gitignore).

# ---- Runtime ----
PAPER_MODE=true               # true = simulated fills, false = live orders
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata

# ---- Database ----
ALPHAGRID_DB_URL=sqlite:///./alphagrid.db   # swap to postgres://... at week 11

# ---- Redis (signal bus) ----
REDIS_URL=redis://127.0.0.1:6379/0

# ---- Angel One (Indian equities) ----
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=             # base32 secret for 2FA
ANGEL_USE_SANDBOX=true         # paper-trade against Angel One's sandbox; flip to false for live

# ---- Binance (PUBLIC MARKET DATA ONLY — no auth needed) ----
# Used for funding-rate, OHLC, WebSocket ticks. India users CAN read these
# endpoints (they're public); they CANNOT place orders via Binance. Leave
# keys blank — they're only here for completeness if Binance ever relaxes.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ---- Bybit (LIVE ORDER PLACEMENT) ----
# Bybit accepts Indian users with KYC and gives full API trading access.
# Required only when PAPER_MODE=false. Until paper-to-live triggers pass,
# these stay blank and execution.broker.NullBroker is used.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# ---- Data providers ----
GLASSNODE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=alphagrid/0.1

# ---- LLM (for reasoning logs) ----
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
LLM_PROVIDER=anthropic         # anthropic | google
LLM_MODEL=claude-haiku-4-5-20251001

# ---- Vertex AI / Google Agent Platform ----
# Used for the reasoning layer on top of FinBERT (news summaries, trade
# explanations, dashboard narration). FinBERT still does the raw scoring.
# Auth: set VERTEX_API_KEY for laptop dev, leave blank + use ADC on Azure.
VERTEX_API_KEY=
VERTEX_PROJECT=                # e.g. project-8c5a7360-1ddb-4649-91d
VERTEX_LOCATION=us-central1
VERTEX_FAST_MODEL=gemini-3.1-flash-lite-preview
VERTEX_REASONING_MODEL=gemini-3.1-pro-preview
VERTEX_CODING_MODEL=claude-sonnet-4-6
VERTEX_MAX_OUTPUT_TOKENS=512
VERTEX_ENABLE_LLM_SUMMARIES=false

# ---- Telegram (approval gate + alerts) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
HUMAN_APPROVAL_REQUIRED=true   # flip to false after the week-1 burn-in
